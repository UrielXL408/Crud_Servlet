<?xml version="1.0" encoding="UTF-8"?>
<web-app version="6.0" xmlns="https://jakarta.ee/xml/ns/jakartaee" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd">
    <servlet>
        <servlet-name>Servlet_Alumno</servlet-name>
        <servlet-class>control.Servlet_Alumno</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>Servlet_login</servlet-name>
        <servlet-class>control.Servlet_login</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>Servlet_Login</servlet-name>
        <servlet-class>control.Servlet_Login</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Servlet_Alumno</servlet-name>
        <url-pattern>/Servlet_Alumno</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>Servlet_login</servlet-name>
        <url-pattern>/Servlet_login</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>Servlet_Login</servlet-name>
        <url-pattern>/Servlet_Login</url-pattern>
    </servlet-mapping>
</web-app>
